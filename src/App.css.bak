/* ========================================
   PB PORTRAITS - CREATIVE DESIGN STUDIO
   Minimalist Black & White Theme
   ======================================== */

@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Poppins:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap');

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --primary-color: #1a1a1a;
  --secondary-color: #333333;
  --accent-color: #666666;
  --highlight-color: #000000;
  --danger-color: #dc3545;
  --warning-color: #ffc107;
  --dark-bg: #ffffff;
  --card-bg: #fafafa;
  --text-primary: #1a1a1a;
  --text-secondary: #666666;
  --gradient-1: linear-gradient(135deg, #1a1a1a 0%, #4a4a4a 100%);
  --gradient-2: linear-gradient(135deg, #ffffff 0%, #f5f5f5 100%);
  --glow-dark: 0 0 30px rgba(0, 0, 0, 0.15);
  --shadow-light: 0 2px 10px rgba(0, 0, 0, 0.05);
  --shadow-medium: 0 8px 30px rgba(0, 0, 0, 0.1);
  --shadow-heavy: 0 15px 50px rgba(0, 0, 0, 0.15);
  --border-color: #e5e5e5;
}

body {
  font-family: 'Poppins', sans-serif;
  background-color: var(--dark-bg);
  color: var(--text-primary);
  overflow-x: hidden;
  line-height: 1.7;
}

h1, h2, h3, h4, h5, h6 {
  font-family: 'Playfair Display', serif;
  font-weight: 600;
}

/* ========================================
   LOADER STYLES
   ======================================== */

.loader-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  background: var(--dark-bg);
  z-index: 9999;
}

.cyber-loader {
  position: relative;
  width: 150px;
  height: 150px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.loader-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 3px solid transparent;
  border-radius: 50%;
  animation: rotate 1.5s linear infinite;
}

.loader-ring:nth-child(1) {
  border-top-color: #1a1a1a;
  animation-delay: 0s;
}

.loader-ring:nth-child(2) {
  width: 80%;
  height: 80%;
  border-right-color: #333333;
  animation-delay: 0.2s;
  animation-direction: reverse;
}

.loader-ring:nth-child(3) {
  width: 60%;
  height: 60%;
  border-bottom-color: #666666;
  animation-delay: 0.4s;
}

.loader-text {
  font-family: 'Playfair Display', serif;
  font-size: 0.9rem;
  color: #1a1a1a;
  letter-spacing: 3px;
  animation: pulse 1s ease-in-out infinite;
}

@keyframes rotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* ========================================
   NAVBAR STYLES
   ======================================== */

.navbar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  padding: 1rem 5%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  z-index: 1000;
  border-bottom: 1px solid var(--border-color);
  transition: all 0.3s ease;
}

.navbar.scrolled {
  padding: 0.8rem 5%;
  box-shadow: var(--shadow-medium);
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}

.logo-icon {
  width: 50px;
  height: 50px;
  background: #1a1a1a;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 1.5rem;
  color: #ffffff;
  transition: all 0.3s ease;
}

.nav-logo:hover .logo-icon {
  transform: scale(1.05);
}

.logo-text {
  font-family: 'Playfair Display', serif;
  font-size: 1.6rem;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 1px;
}

.nav-links {
  display: flex;
  gap: 2rem;
  list-style: none;
}

.nav-links a {
  color: var(--text-secondary);
  text-decoration: none;
  font-size: 1rem;
  font-weight: 500;
  letter-spacing: 1px;
  transition: all 0.3s ease;
  position: relative;
}

.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -5px;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--gradient-1);
  transition: width 0.3s ease;
}

.nav-links a:hover {
  color: var(--primary-color);
}

.nav-links a:hover::after {
  width: 100%;
}

.nav-cta {
  background: #1a1a1a;
  color: #ffffff;
  padding: 0.9rem 1.8rem;
  border: none;
  border-radius: 0;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  text-transform: uppercase;
  letter-spacing: 2px;
}

.nav-cta:hover {
  transform: translateY(-2px);
  background: #333333;
  box-shadow: var(--shadow-medium);
}

.mobile-menu-btn {
  display: none;
  flex-direction: column;
  gap: 5px;
  cursor: pointer;
  padding: 10px;
}

.mobile-menu-btn span {
  width: 25px;
  height: 2px;
  background: var(--primary-color);
  transition: all 0.3s ease;
}

/* ========================================
   HERO SECTION
   ======================================== */

.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 0;
  position: relative;
  overflow: hidden;
  background: #000;
}

/* Hero Slider Background */
.hero-slider-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.hero-slide {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-size: cover;
  background-position: center;
  opacity: 0;
  transition: opacity 1.2s ease-in-out, transform 6s ease-out;
  transform: scale(1);
}

.hero-slide.active {
  opacity: 1;
  transform: scale(1.03);
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    to right,
    rgba(0, 0, 0, 0.85) 0%,
    rgba(0, 0, 0, 0.6) 50%,
    rgba(0, 0, 0, 0.3) 100%
  );
  z-index: 1;
}

/* Slider Controls */
.hero-slider-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.3);
  color: #fff;
  width: 50px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 10;
  transition: all 0.3s ease;
  font-size: 1rem;
}

.hero-slider-btn:hover {
  background: #fff;
  color: #000;
  border-color: #fff;
}

.hero-slider-btn.prev {
  left: 30px;
}

.hero-slider-btn.next {
  right: 30px;
}

/* Hero Content */
.hero-content {
  position: relative;
  z-index: 5;
  width: 100%;
  max-width: 700px;
  padding: 0 5%;
  margin-left: 5%;
}

.hero-text {
  animation: fadeUp 1s ease-out;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(40px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero-tagline {
  display: inline-block;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 4px;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.2);
}

.hero-title {
  font-family: 'Playfair Display', serif;
  font-size: 4.5rem;
  font-weight: 500;
  line-height: 1.1;
  color: #fff;
  margin-bottom: 1.5rem;
}

.hero-title-highlight {
  font-style: italic;
  background: linear-gradient(120deg, #fff, #ccc);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-description {
  font-size: 1.1rem;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.8;
  margin-bottom: 2.5rem;
  max-width: 500px;
}

.hero-buttons {
  display: flex;
  gap: 1rem;
  margin-bottom: 3rem;
}

.hero-buttons .btn-primary {
  background: #fff;
  color: #000;
  padding: 1rem 2rem;
  border: none;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2px;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}

.hero-buttons .btn-primary:hover {
  background: #f0f0f0;
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(255, 255, 255, 0.2);
}

.hero-buttons .btn-secondary {
  background: transparent;
  color: #fff;
  padding: 1rem 2rem;
  border: 1px solid rgba(255, 255, 255, 0.4);
  font-family: 'Montserrat', sans-serif;
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2px;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}

.hero-buttons .btn-secondary:hover {
  background: #fff;
  color: #000;
  border-color: #fff;
}

/* Hero Stats */
.hero-stats {
  display: flex;
  gap: 3rem;
}

.hero-stat {
  text-align: left;
}

.hero-stat .stat-number {
  display: block;
  font-family: 'Playfair Display', serif;
  font-size: 2.5rem;
  font-weight: 600;
  color: #fff;
}

.hero-stat .stat-label {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: rgba(255, 255, 255, 0.5);
}

/* Slider Dots with Labels */
.hero-slider-dots {
  position: absolute;
  bottom: 50px;
  right: 5%;
  display: flex;
  flex-direction: column;
  gap: 15px;
  z-index: 10;
}

.hero-dot {
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 8px 0;
  text-align: right;
  transition: all 0.3s ease;
}

.hero-dot .dot-label {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: rgba(255, 255, 255, 0.4);
  transition: all 0.3s ease;
  position: relative;
  padding-right: 20px;
}

.hero-dot .dot-label::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8px;
  height: 1px;
  background: rgba(255, 255, 255, 0.4);
  transition: all 0.3s ease;
}

.hero-dot:hover .dot-label,
.hero-dot.active .dot-label {
  color: #fff;
}

.hero-dot:hover .dot-label::after,
.hero-dot.active .dot-label::after {
  width: 30px;
  background: #fff;
}

/* Responsive Hero */
@media (max-width: 1024px) {
  .hero-title {
    font-size: 3.5rem;
  }
  
  .hero-content {
    max-width: 600px;
  }
  
  .hero-slider-dots {
    bottom: 30px;
    right: auto;
    left: 5%;
    flex-direction: row;
    gap: 20px;
  }
  
  .hero-dot .dot-label::after {
    display: none;
  }
  
  .hero-dot .dot-label {
    padding-right: 0;
  }
}

@media (max-width: 768px) {
  .hero-title {
    font-size: 2.8rem;
  }
  
  .hero-content {
    margin-left: 0;
    text-align: center;
    padding: 0 5%;
  }
  
  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .hero-description {
    text-align: center;
  }
  
  .hero-buttons {
    justify-content: center;
    flex-wrap: wrap;
  }
  
  .hero-stats {
    justify-content: center;
  }
  
  .hero-slider-btn {
    width: 40px;
    height: 40px;
  }
  
  .hero-slider-btn.prev {
    left: 15px;
  }
  
  .hero-slider-btn.next {
    right: 15px;
  }
  
  .hero-slider-dots {
    left: 50%;
    transform: translateX(-50%);
  }
  
  .hero-overlay {
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.7) 0%,
      rgba(0, 0, 0, 0.85) 100%
    );
  }
}

@media (max-width: 480px) {
  .hero-title {
    font-size: 2.2rem;
  }
  
  .hero-stats {
    gap: 2rem;
  }
  
  .hero-stat .stat-number {
    font-size: 2rem;
  }
  
  .hero-buttons .btn-primary,
  .hero-buttons .btn-secondary {
    padding: 0.9rem 1.5rem;
    font-size: 0.8rem;
  }
}

.cyber-grid {
  display: none;
}

@keyframes gridMove {
  0% { transform: perspective(500px) rotateX(60deg) translateY(0); }
  100% { transform: perspective(500px) rotateX(60deg) translateY(50px); }
}

.floating-particles {
  position: absolute;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.particle {
  position: absolute;
  width: 4px;
  height: 4px;
  background: var(--primary-color);
  border-radius: 50%;
  animation: float 15s infinite;
  opacity: 0.6;
}

.particle:nth-child(1) { left: 10%; animation-delay: 0s; }
.particle:nth-child(2) { left: 20%; animation-delay: 2s; }
.particle:nth-child(3) { left: 30%; animation-delay: 4s; }
.particle:nth-child(4) { left: 40%; animation-delay: 6s; }
.particle:nth-child(5) { left: 50%; animation-delay: 8s; }
.particle:nth-child(6) { left: 60%; animation-delay: 10s; }
.particle:nth-child(7) { left: 70%; animation-delay: 12s; }
.particle:nth-child(8) { left: 80%; animation-delay: 14s; }
.particle:nth-child(9) { left: 90%; animation-delay: 16s; }
.particle:nth-child(10) { left: 95%; animation-delay: 18s; }

@keyframes float {
  0%, 100% { 
    transform: translateY(100vh) scale(0);
    opacity: 0;
  }
  10% {
    opacity: 0.6;
  }
  90% {
    opacity: 0.6;
  }
  100% { 
    transform: translateY(-100vh) scale(1);
    opacity: 0;
  }
}

.hero-content {
  max-width: 1400px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 4rem;
  align-items: center;
  position: relative;
  z-index: 1;
}

.hero-text {
  animation: fadeInLeft 1s ease-out;
}

@keyframes fadeInLeft {
  from {
    opacity: 0;
    transform: translateX(-50px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.2);
  padding: 0.6rem 1.2rem;
  font-size: 0.85rem;
  color: #ffffff;
  margin-bottom: 1.8rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  backdrop-filter: blur(10px);
}

.hero-badge .badge-icon {
  color: #ffc107;
  font-size: 0.9rem;
}

.badge-dot {
  width: 8px;
  height: 8px;
  background: var(--accent-color);
  border-radius: 50%;
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.hero-title {
  font-size: 4rem;
  font-weight: 600;
  line-height: 1.1;
  margin-bottom: 1.5rem;
  color: #ffffff;
  font-family: 'Playfair Display', serif;
}

.hero-title .highlight {
  font-style: italic;
  position: relative;
  display: inline-block;
}

.hero-title .highlight::after {
  content: '';
  position: absolute;
  bottom: 5px;
  left: 0;
  width: 100%;
  height: 8px;
  background: rgba(255, 255, 255, 0.15);
  z-index: -1;
}

.hero-title span {
  font-style: italic;
  color: #ffffff;
}

.hero-description {
  font-size: 1.1rem;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 1.5rem;
  line-height: 1.9;
  max-width: 550px;
}

.hero-buttons {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.btn-primary {
  background: #ffffff;
  color: #0a0a0a;
  padding: 1.1rem 2.5rem;
  border: none;
  border-radius: 0;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  align-items: center;
  gap: 12px;
  text-transform: uppercase;
  letter-spacing: 2px;
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(0,0,0,0.1), transparent);
  transition: left 0.5s ease;
}

.btn-primary:hover::before {
  left: 100%;
}

.btn-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 15px 40px rgba(255, 255, 255, 0.25);
}

.btn-secondary {
  background: transparent;
  color: #ffffff;
  padding: 1.1rem 2.5rem;
  border: 1px solid rgba(255, 255, 255, 0.4);
  border-radius: 0;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  align-items: center;
  gap: 12px;
  text-transform: uppercase;
  letter-spacing: 2px;
}

.btn-secondary:hover {
  background: #ffffff;
  color: #1a1a1a;
  transform: translateY(-3px);
}

.hero-visual {
  position: relative;
  animation: fadeInRight 1s ease-out;
}

@keyframes fadeInRight {
  from {
    opacity: 0;
    transform: translateX(50px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.hero-image-container {
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
}

.hero-image {
  width: 100%;
  height: auto;
  border-radius: 20px;
  filter: brightness(0.9);
}

.hero-image-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(0, 102, 204, 0.2) 0%, rgba(0, 184, 148, 0.1) 100%);
  pointer-events: none;
}

.scan-line {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 3px;
  background: var(--gradient-1);
  animation: scan 3s linear infinite;
  opacity: 0.7;
}

@keyframes scan {
  0% { top: 0; }
  100% { top: 100%; }
}

.floating-card {
  position: absolute;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border: 1px solid var(--border-color);
  border-radius: 15px;
  padding: 1rem 1.5rem;
  display: flex;
  align-items: center;
  gap: 12px;
  animation: floatCard 3s ease-in-out infinite;
  box-shadow: var(--shadow-medium);
}

.floating-card.card-1 {
  top: 10%;
  left: -10%;
  animation-delay: 0s;
}

.floating-card.card-2 {
  bottom: 20%;
  right: -5%;
  animation-delay: 1s;
}

.floating-card.card-3 {
  bottom: 5%;
  left: 5%;
  animation-delay: 2s;
}

@keyframes floatCard {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

.card-icon {
  width: 45px;
  height: 45px;
  background: #1a1a1a;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 1.2rem;
  color: #ffffff;
}

.card-content h4 {
  font-size: 0.9rem;
  color: var(--text-primary);
  margin-bottom: 2px;
}

.card-content p {
  font-size: 0.8rem;
  color: var(--accent-color);
}

/* ========================================
   SECTION STYLES
   ======================================== */

section {
  padding: 6rem 5%;
  position: relative;
}

.section-header {
  text-align: center;
  margin-bottom: 4rem;
}

.section-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: transparent;
  border: 1px solid #1a1a1a;
  padding: 0.5rem 1.5rem;
  border-radius: 0;
  font-size: 0.8rem;
  color: #1a1a1a;
  margin-bottom: 1rem;
  text-transform: uppercase;
  letter-spacing: 3px;
  font-family: 'Montserrat', sans-serif;
}

.section-title {
  font-size: 3rem;
  font-weight: 600;
  margin-bottom: 1rem;
  font-family: 'Playfair Display', serif;
}

.section-title span {
  font-style: italic;
}

.section-description {
  font-size: 1.1rem;
  color: var(--text-secondary);
  max-width: 600px;
  margin: 0 auto;
}

/* ========================================
   SERVICES HERO SLIDER
   ======================================== */

/* ========================================
   SERVICES SECTION
   ======================================== */

.services {
  background: #fafafa;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
  gap: 2rem;
  max-width: 1400px;
  margin: 0 auto;
}

.service-card {
  background: #ffffff;
  border: 1px solid #e5e5e5;
  border-radius: 0;
  overflow: hidden;
  transition: all 0.4s ease;
  position: relative;
  box-shadow: none;
}

.service-card::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 3px;
  background: #1a1a1a;
  transform: scaleX(0);
  transition: transform 0.4s ease;
  z-index: 10;
}

.service-card:hover {
  transform: translateY(-5px);
  border-color: #1a1a1a;
  box-shadow: var(--shadow-medium);
}

.service-card:hover::before {
  transform: scaleX(1);
}

.service-card > * {
  position: relative;
  z-index: 1;
}

.service-image {
  position: relative;
  height: 200px;
  overflow: hidden;
}

.service-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
  filter: grayscale(20%);
}

.service-card:hover .service-image img {
  transform: scale(1.1);
  filter: grayscale(0%);
}

.service-content {
  padding: 1.5rem 2rem 2rem;
}

.service-icon {
  width: 50px;
  height: 50px;
  background: #1a1a1a;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 1.2rem;
  color: #ffffff;
  margin-bottom: 1rem;
  margin-top: -40px;
  position: relative;
  z-index: 5;
  transition: all 0.4s ease;
  border: 3px solid #ffffff;
}

.service-card:hover .service-icon {
  background: #333333;
  transform: scale(1.05);
}

.service-content h3 {
  font-size: 1.3rem;
  margin-bottom: 0.8rem;
  color: var(--text-primary);
  font-family: 'Playfair Display', serif;
}

.service-content p {
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 1.2rem;
  font-size: 0.95rem;
}

.service-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: #1a1a1a;
  text-decoration: none;
  font-weight: 600;
  font-size: 0.9rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  transition: all 0.3s ease;
}

.service-link:hover {
  gap: 12px;
}

/* Course Price Tag & Meta */
.course-price-tag {
  display: inline-block;
  background: #1a1a1a;
  color: #ffffff;
  padding: 0.4rem 1rem;
  border-radius: 20px;
  font-weight: 700;
  font-size: 1.1rem;
  margin-bottom: 0.8rem;
}

.course-meta {
  display: flex;
  gap: 1rem;
  margin-bottom: 0.8rem;
  flex-wrap: wrap;
}

.course-meta span {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 0.85rem;
  color: var(--text-secondary);
  background: rgba(0, 0, 0, 0.03);
  padding: 0.25rem 0.6rem;
  border-radius: 6px;
}

/* Course Detail Meta */
.course-detail-meta {
  display: flex;
  gap: 1.5rem;
  margin: 1.5rem 0;
  flex-wrap: wrap;
}

.course-meta-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 1rem;
  color: var(--text-secondary);
  background: rgba(0, 0, 0, 0.03);
  padding: 0.5rem 1rem;
  border-radius: 8px;
  border: 1px solid rgba(0, 0, 0, 0.08);
}

.course-meta-item svg {
  font-size: 1.1rem;
  color: #1a1a1a;
}

/* ========================================
   ABOUT SECTION
   ======================================== */

.about {
  background: var(--dark-bg);
}

.about-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  max-width: 1400px;
  margin: 0 auto;
}

.about-image {
  position: relative;
}

.about-image img {
  width: 100%;
  border-radius: 20px;
  filter: brightness(0.9);
}

.about-image::before {
  content: '';
  position: absolute;
  top: -20px;
  left: -20px;
  width: 100%;
  height: 100%;
  border: 2px solid var(--primary-color);
  border-radius: 20px;
  z-index: -1;
}

.about-stats {
  position: absolute;
  bottom: -30px;
  right: -30px;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}

.stat-box {
  background: var(--card-bg);
  border: 1px solid rgba(0, 100, 200, 0.15);
  border-radius: 15px;
  padding: 1.5rem;
  text-align: center;
  box-shadow: var(--shadow-light);
}

.stat-box h3 {
  font-size: 2rem;
  background: var(--gradient-1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-box p {
  font-size: 0.9rem;
  color: var(--text-secondary);
}

.about-text h2 {
  font-size: 2.5rem;
  margin-bottom: 1.5rem;
}

.about-text h2 span {
  background: var(--gradient-1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.about-text p {
  color: var(--text-secondary);
  margin-bottom: 1.5rem;
  line-height: 1.8;
}

.about-features {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
  margin-top: 2rem;
}

.about-feature {
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--text-primary);
}

.about-feature svg {
  color: var(--accent-color);
  font-size: 1.2rem;
}

/* ========================================
   FEATURES SECTION
   ======================================== */

.features {
  background: #ffffff;
  position: relative;
  overflow: hidden;
}

.features::before {
  display: none;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2rem;
  max-width: 1400px;
  margin: 0 auto;
}

.feature-card {
  background: #fafafa;
  border: 1px solid #e5e5e5;
  border-radius: 0;
  padding: 2rem;
  text-align: center;
  transition: all 0.4s ease;
  box-shadow: none;
}

.feature-card:hover {
  transform: translateY(-5px);
  border-color: #1a1a1a;
  box-shadow: var(--shadow-medium);
}

.feature-icon {
  width: 70px;
  height: 70px;
  background: #1a1a1a;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 1.5rem;
  color: #ffffff;
  margin: 0 auto 1.5rem;
}

.feature-card h3 {
  font-size: 1.2rem;
  margin-bottom: 0.8rem;
}

.feature-card p {
  color: var(--text-secondary);
  font-size: 0.95rem;
}

/* ========================================
   STATS SECTION
   ======================================== */

.stats-section {
  background: #1a1a1a;
  padding: 5rem 5%;
  position: relative;
}

.stats-container {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
  max-width: 1200px;
  margin: 0 auto;
}

.stat-item {
  text-align: center;
  padding: 2rem;
  background: transparent;
  border-radius: 0;
  border: 1px solid rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
  box-shadow: none;
}

.stat-item:hover {
  border-color: #ffffff;
  transform: translateY(-5px);
}

.stat-number {
  font-size: 3.5rem;
  font-weight: 600;
  color: #ffffff;
  display: block;
  font-family: 'Playfair Display', serif;
}

.stat-label {
  color: rgba(255, 255, 255, 0.7);
  font-size: 1rem;
  margin-top: 0.5rem;
  text-transform: uppercase;
  letter-spacing: 2px;
}

/* ========================================
   TESTIMONIALS SECTION
   ======================================== */

.testimonials {
  background: var(--gradient-2);
}

.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
  gap: 2rem;
  max-width: 1400px;
  margin: 0 auto;
}

.testimonial-card {
  background: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(0, 100, 200, 0.15);
  border-radius: 20px;
  padding: 2.5rem;
  position: relative;
  box-shadow: var(--shadow-medium);
}

.testimonial-card::before {
  content: '"';
  position: absolute;
  top: 20px;
  right: 30px;
  font-size: 5rem;
  color: rgba(0, 212, 255, 0.1);
  font-family: serif;
  line-height: 1;
}

.testimonial-content {
  margin-bottom: 1.5rem;
}

.testimonial-content p {
  color: var(--text-secondary);
  font-size: 1.05rem;
  line-height: 1.8;
  font-style: italic;
}

.testimonial-author {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.author-image {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid var(--primary-color);
}

.author-info h4 {
  font-size: 1.1rem;
  color: var(--text-primary);
}

.author-info p {
  color: var(--primary-color);
  font-size: 0.9rem;
}

.testimonial-rating {
  margin-top: 1rem;
  color: var(--warning-color);
  font-size: 1.1rem;
}

/* ========================================
   CONTACT SECTION
   ======================================== */

.contact {
  background: #fafafa;
}

.contact-content {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 4rem;
  max-width: 1400px;
  margin: 0 auto;
}

.contact-info h3 {
  font-size: 1.8rem;
  margin-bottom: 1.5rem;
}

.contact-info > p {
  color: var(--text-secondary);
  margin-bottom: 2rem;
  line-height: 1.8;
}

.contact-details {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.contact-icon {
  width: 50px;
  height: 50px;
  background: #1a1a1a;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 1.2rem;
  color: #ffffff;
}

.contact-item-text h4 {
  font-size: 1rem;
  color: var(--text-primary);
  margin-bottom: 2px;
}

.contact-item-text p {
  color: var(--text-secondary);
  font-size: 0.95rem;
}

.contact-form {
  background: #ffffff;
  border: 1px solid #e5e5e5;
  box-shadow: var(--shadow-light);
  border-radius: 0;
  padding: 2.5rem;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  margin-bottom: 1.5rem;
}

.form-group {
  margin-bottom: 1.5rem;
}

.form-group label {
  display: block;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
  font-weight: 500;
}

.form-group input,
.form-group textarea,
.form-group select {
  width: 100%;
  padding: 1rem;
  background: #fafafa;
  border: 1px solid #e5e5e5;
  border-radius: 0;
  color: var(--text-primary);
  font-family: 'Poppins', sans-serif;
  font-size: 1rem;
  transition: all 0.3s ease;
}

.form-group input:focus,
.form-group textarea:focus,
.form-group select:focus {
  outline: none;
  border-color: #1a1a1a;
  box-shadow: none;
}

.form-group textarea {
  min-height: 150px;
  resize: vertical;
}

.form-submit {
  width: 100%;
  background: #1a1a1a;
  color: #ffffff;
  padding: 1.2rem;
  border: none;
  border-radius: 0;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  text-transform: uppercase;
  letter-spacing: 2px;
}

.form-submit:hover {
  transform: translateY(-2px);
  background: #333333;
  box-shadow: var(--shadow-medium);
}

/* ========================================
   FOOTER
   ======================================== */

.footer {
  background: #1a1a1a;
  border-top: none;
  padding: 5rem 5% 2rem;
}

.footer-content {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 3rem;
  max-width: 1400px;
  margin: 0 auto;
  padding-bottom: 3rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.15);
}

.footer-brand {
  max-width: 350px;
}

.footer-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 1.5rem;
}

.footer-logo-icon {
  width: 45px;
  height: 45px;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 1.2rem;
  color: #1a1a1a;
}

.footer-logo-text {
  font-family: 'Playfair Display', serif;
  font-size: 1.4rem;
  font-weight: 600;
  color: #ffffff;
}

.footer-brand p {
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.7;
  margin-bottom: 1.5rem;
}

.footer-social {
  display: flex;
  gap: 1rem;
}

.social-link {
  width: 40px;
  height: 40px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #ffffff;
  text-decoration: none;
  transition: all 0.3s ease;
}

.social-link:hover {
  background: #ffffff;
  color: #1a1a1a;
  color: var(--dark-bg);
  transform: translateY(-3px);
}

.footer-links h4 {
  font-size: 1.1rem;
  color: #ffffff;
  margin-bottom: 1.5rem;
}

.footer-links ul {
  list-style: none;
}

.footer-links li {
  margin-bottom: 0.8rem;
}

.footer-links a {
  color: rgba(255, 255, 255, 0.7);
  text-decoration: none;
  transition: all 0.3s ease;
}

.footer-links a:hover {
  color: var(--primary-color);
  padding-left: 5px;
}

.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 2rem;
  max-width: 1400px;
  margin: 0 auto;
}

.footer-bottom p {
  color: rgba(255, 255, 255, 0.6);
  font-size: 0.95rem;
}

.footer-bottom-links {
  display: flex;
  gap: 2rem;
}

.footer-bottom-links a {
  color: rgba(255, 255, 255, 0.6);
  text-decoration: none;
  font-size: 0.95rem;
  transition: color 0.3s ease;
}

.footer-bottom-links a:hover {
  color: var(--primary-color);
}

/* ========================================
   RESPONSIVE DESIGN
   ======================================== */

@media (max-width: 1200px) {
  .hero-title {
    font-size: 3rem;
  }
  
  .footer-content {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 992px) {
  .nav-links {
    display: none;
  }
  
  .mobile-menu-btn {
    display: flex;
  }
  
  .hero-content {
    grid-template-columns: 1fr;
    text-align: center;
  }
  
  .hero-buttons {
    justify-content: center;
  }
  
  .hero-visual {
    max-width: 500px;
    margin: 0 auto;
  }
  
  .floating-card {
    display: none;
  }
  
  .about-content {
    grid-template-columns: 1fr;
  }
  
  .about-image {
    max-width: 500px;
    margin: 0 auto;
  }
  
  .contact-content {
    grid-template-columns: 1fr;
  }
  
  .stats-container {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* ========================================
   BLOG SECTION
   ======================================== */

.blog-section {
  background: var(--gradient-2);
  padding: 6rem 5%;
}

.blog-loading {
  text-align: center;
  padding: 4rem;
  color: var(--text-secondary);
}

.blog-loading .loader-ring {
  width: 50px;
  height: 50px;
  margin: 0 auto 1rem;
  border: 3px solid transparent;
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: rotate 1s linear infinite;
}

.blog-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
  gap: 2rem;
  max-width: 1400px;
  margin: 0 auto;
}

.blog-card {
  background: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(0, 100, 200, 0.15);
  border-radius: 20px;
  overflow: hidden;
  transition: all 0.4s ease;
  box-shadow: var(--shadow-medium);
}

.blog-card:hover {
  transform: translateY(-10px);
  border-color: var(--primary-color);
  box-shadow: var(--glow-cyan);
}

.blog-image {
  position: relative;
  height: 220px;
  overflow: hidden;
}

.blog-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.blog-card:hover .blog-image img {
  transform: scale(1.1);
}

.blog-category {
  position: absolute;
  top: 15px;
  left: 15px;
  background: var(--gradient-1);
  color: var(--dark-bg);
  padding: 0.4rem 1rem;
  border-radius: 50px;
  font-size: 0.8rem;
  font-weight: 600;
  font-family: 'Orbitron', sans-serif;
}

.blog-content {
  padding: 1.5rem;
}

.blog-meta {
  display: flex;
  gap: 1.5rem;
  margin-bottom: 1rem;
  font-size: 0.85rem;
  color: var(--text-secondary);
}

.blog-meta span {
  display: flex;
  align-items: center;
  gap: 5px;
}

.blog-meta svg {
  color: var(--primary-color);
}

.blog-title {
  font-size: 1.3rem;
  font-weight: 600;
  margin-bottom: 0.8rem;
  color: var(--text-primary);
  line-height: 1.4;
}

.blog-excerpt {
  color: var(--text-secondary);
  font-size: 0.95rem;
  line-height: 1.6;
  margin-bottom: 1.5rem;
}

.blog-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 1rem;
  border-top: 1px solid rgba(0, 100, 200, 0.1);
}

.blog-author {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--text-secondary);
  font-size: 0.9rem;
}

.blog-author svg {
  color: var(--primary-color);
}

.blog-read-more {
  display: flex;
  align-items: center;
  gap: 8px;
  background: transparent;
  border: none;
  color: var(--primary-color);
  font-family: 'Orbitron', sans-serif;
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.blog-read-more:hover {
  gap: 12px;
  color: var(--accent-color);
}

/* Blog Modal */
.blog-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(10, 14, 23, 0.95);
  z-index: 2000;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 2rem;
  overflow-y: auto;
}

.blog-modal {
  background: var(--card-bg);
  border: 1px solid rgba(0, 212, 255, 0.2);
  border-radius: 20px;
  max-width: 900px;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  position: relative;
  animation: modalSlideIn 0.3s ease;
}

@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: translateY(-30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-close {
  position: absolute;
  top: 20px;
  right: 20px;
  width: 40px;
  height: 40px;
  background: rgba(255, 71, 87, 0.1);
  border: 1px solid var(--danger-color);
  border-radius: 50%;
  color: var(--danger-color);
  font-size: 1.5rem;
  cursor: pointer;
  transition: all 0.3s ease;
  z-index: 10;
}

.modal-close:hover {
  background: var(--danger-color);
  color: white;
}

.modal-image {
  height: 300px;
  overflow: hidden;
}

.modal-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.modal-content {
  padding: 2rem;
}

.modal-category {
  display: inline-block;
  background: var(--gradient-1);
  color: var(--dark-bg);
  padding: 0.4rem 1rem;
  border-radius: 50px;
  font-size: 0.8rem;
  font-weight: 600;
  font-family: 'Orbitron', sans-serif;
  margin-bottom: 1rem;
}

.modal-content h2 {
  font-size: 2rem;
  margin-bottom: 1rem;
  line-height: 1.3;
}

.modal-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 1.5rem;
  margin-bottom: 1rem;
  color: var(--text-secondary);
  font-size: 0.9rem;
}

.modal-meta span {
  display: flex;
  align-items: center;
  gap: 8px;
}

.modal-meta svg {
  color: var(--primary-color);
}

.modal-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
  margin-bottom: 2rem;
}

.modal-tags .tag {
  display: flex;
  align-items: center;
  gap: 5px;
  background: rgba(0, 212, 255, 0.1);
  border: 1px solid rgba(0, 212, 255, 0.2);
  color: var(--primary-color);
  padding: 0.3rem 0.8rem;
  border-radius: 50px;
  font-size: 0.8rem;
}

.modal-body {
  color: var(--text-secondary);
  line-height: 1.8;
  font-size: 1.05rem;
}

.modal-body p {
  margin-bottom: 1.5rem;
}

.modal-body h3 {
  color: var(--text-primary);
  margin: 2rem 0 1rem;
  font-size: 1.3rem;
}

.modal-body ul, .modal-body ol {
  margin-left: 1.5rem;
  margin-bottom: 1.5rem;
}

.modal-body li {
  margin-bottom: 0.5rem;
}

/* Form Alert */
.form-alert {
  padding: 1rem;
  border-radius: 10px;
  margin-bottom: 1.5rem;
  font-weight: 500;
}

.form-alert.success {
  background: rgba(46, 213, 115, 0.1);
  border: 1px solid #2ed573;
  color: #2ed573;
}

.form-alert.error {
  background: rgba(255, 71, 87, 0.1);
  border: 1px solid var(--danger-color);
  color: var(--danger-color);
}

@media (max-width: 768px) {
  .hero-title {
    font-size: 2.2rem;
  }
  
  .section-title {
    font-size: 2rem;
  }
  
  .hero-slider-btn {
    width: 40px;
    height: 40px;
    font-size: 1rem;
  }
  
  .hero-slider-btn.prev {
    left: 10px;
  }
  
  .hero-slider-btn.next {
    right: 10px;
  }
  
  .hero-stats-cards {
    flex-direction: row;
    flex-wrap: wrap;
    margin-top: 2rem;
  }
  
  .hero-stat-card {
    flex: 1;
    min-width: 140px;
  }
  
  .hero-slide-title {
    bottom: 120px;
    right: 20px;
  }
  
  .hero-slide-title span {
    font-size: 1rem;
  }
  
  .services-grid {
    grid-template-columns: 1fr;
  }
  
  .form-row {
    grid-template-columns: 1fr;
  }
  
  .footer-content {
    grid-template-columns: 1fr;
    text-align: center;
  }
  
  .footer-brand {
    max-width: 100%;
  }
  
  .footer-social {
    justify-content: center;
  }
  
  .footer-bottom {
    flex-direction: column;
    gap: 1rem;
    text-align: center;
  }
  
  .about-features {
    grid-template-columns: 1fr;
  }
  
  .about-stats {
    position: static;
    margin-top: 2rem;
  }
  
  .blog-grid {
    grid-template-columns: 1fr;
  }
  
  .modal-content h2 {
    font-size: 1.5rem;
  }
  
  .modal-image {
    height: 200px;
  }
  
  .portfolio-grid {
    grid-template-columns: 1fr;
  }
  
  .portfolio-filters {
    flex-wrap: wrap;
  }
}

/* ========================================
   PORTFOLIO SECTION
   ======================================== */

.portfolio {
  background: #0a0a0a;
  padding: 6rem 5%;
}

.portfolio .section-header .section-badge {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.2);
  color: #ffffff;
}

.portfolio .section-title {
  color: #ffffff;
}

.portfolio .section-description {
  color: rgba(255, 255, 255, 0.7);
}

.portfolio-filters {
  display: flex;
  justify-content: center;
  gap: 1rem;
  margin-bottom: 3rem;
  flex-wrap: wrap;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0.8rem 1.5rem;
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.7);
  font-family: 'Montserrat', sans-serif;
  font-size: 0.8rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.filter-btn .filter-count {
  background: rgba(255, 255, 255, 0.1);
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 0.7rem;
  margin-left: 5px;
}

.filter-btn:hover,
.filter-btn.active {
  background: #ffffff;
  color: #0a0a0a;
  border-color: #ffffff;
}

.filter-btn.active .filter-count {
  background: rgba(0, 0, 0, 0.2);
}

.portfolio-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
  max-width: 1600px;
  margin: 0 auto;
}

.portfolio-item {
  position: relative;
  overflow: hidden;
}

.portfolio-item:nth-child(1),
.portfolio-item:nth-child(6),
.portfolio-item:nth-child(11) {
  grid-column: span 2;
  grid-row: span 2;
}

.portfolio-image {
  position: relative;
  aspect-ratio: 1/1;
  overflow: hidden;
  background: #1a1a1a;
}

.portfolio-item:nth-child(1) .portfolio-image,
.portfolio-item:nth-child(6) .portfolio-image,
.portfolio-item:nth-child(11) .portfolio-image {
  aspect-ratio: 1/1;
}

.portfolio-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), filter 0.4s ease;
  filter: grayscale(30%);
}

.portfolio-item:hover .portfolio-image img {
  transform: scale(1.1);
  filter: grayscale(0%);
}

.portfolio-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.3) 50%, transparent 100%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 1.5rem;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.portfolio-item:hover .portfolio-overlay {
  opacity: 1;
}

.portfolio-category {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 0.5rem;
}

.portfolio-overlay h3 {
  color: #ffffff;
  font-size: 1.2rem;
  margin-bottom: 0.5rem;
  font-family: 'Playfair Display', serif;
}

.portfolio-overlay p {
  color: rgba(255, 255, 255, 0.7);
  font-size: 0.85rem;
  margin-bottom: 1rem;
}

.portfolio-expand {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: #ffffff;
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.5);
  padding: 0.5rem 1rem;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  cursor: pointer;
  transition: all 0.3s ease;
  width: fit-content;
}

.portfolio-expand:hover {
  background: #ffffff;
  color: #0a0a0a;
  border-color: #ffffff;
}

/* Load More Button */
.portfolio-load-more {
  text-align: center;
  margin-top: 3rem;
}

.btn-load-more {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.3);
  color: #ffffff;
  padding: 1rem 3rem;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.9rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.btn-load-more span {
  font-size: 0.75rem;
  color: rgba(255, 255, 255, 0.5);
}

.btn-load-more:hover {
  background: #ffffff;
  color: #0a0a0a;
  border-color: #ffffff;
}

.btn-load-more:hover span {
  color: rgba(0, 0, 0, 0.5);
}

/* Portfolio CTA */
.portfolio-cta {
  text-align: center;
  margin-top: 4rem;
  padding-top: 3rem;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.portfolio-cta p {
  color: rgba(255, 255, 255, 0.7);
  font-size: 1rem;
  margin-bottom: 1.5rem;
}

.portfolio-cta .cta-buttons {
  display: flex;
  justify-content: center;
  gap: 1rem;
  flex-wrap: wrap;
}

/* Lightbox Styles */
.lightbox-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.95);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}

.lightbox-content {
  position: relative;
  max-width: 90vw;
  max-height: 90vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lightbox-close {
  position: fixed;
  top: 30px;
  right: 30px;
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.3);
  color: #ffffff;
  width: 50px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 1.2rem;
  transition: all 0.3s ease;
  z-index: 10000;
}

.lightbox-close:hover {
  background: #ffffff;
  color: #0a0a0a;
}

.lightbox-nav {
  position: fixed;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.3);
  color: #ffffff;
  width: 60px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 1.2rem;
  transition: all 0.3s ease;
  z-index: 10000;
}

.lightbox-nav:hover {
  background: #ffffff;
  color: #0a0a0a;
}

.lightbox-nav.prev {
  left: 30px;
}

.lightbox-nav.next {
  right: 30px;
}

.lightbox-image-container {
  text-align: center;
}

.lightbox-image-container img {
  max-width: 70vw;
  max-height: 70vh;
  object-fit: contain;
}

.lightbox-info {
  margin-top: 1.5rem;
  text-align: center;
}

.lightbox-category {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 0.5rem;
  display: block;
}

.lightbox-info h3 {
  color: #ffffff;
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem;
  margin-bottom: 0.5rem;
}

.lightbox-info p {
  color: rgba(255, 255, 255, 0.7);
  font-size: 0.9rem;
}

.lightbox-counter {
  position: fixed;
  bottom: 30px;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255, 255, 255, 0.6);
  font-family: 'Montserrat', sans-serif;
  font-size: 0.9rem;
  letter-spacing: 3px;
}

@media (max-width: 1200px) {
  .portfolio-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  
  .portfolio-item:nth-child(1),
  .portfolio-item:nth-child(6),
  .portfolio-item:nth-child(11) {
    grid-column: span 1;
    grid-row: span 1;
  }
}

@media (max-width: 768px) {
  .portfolio-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .lightbox-nav {
    width: 45px;
    height: 45px;
  }
  
  .lightbox-nav.prev {
    left: 15px;
  }
  
  .lightbox-nav.next {
    right: 15px;
  }
  
  .lightbox-image-container img {
    max-width: 90vw;
    max-height: 60vh;
  }
}

@media (max-width: 480px) {
  .portfolio-grid {
    grid-template-columns: 1fr;
  }
  
  .filter-btn {
    padding: 0.6rem 1rem;
    font-size: 0.75rem;
  }
}

@media (max-width: 480px) {
  .hero {
    padding: 6rem 4% 3rem;
  }
  
  section {
    padding: 4rem 4%;
  }
  
  .hero-title {
    font-size: 1.8rem;
  }
  
  .stats-container {
    grid-template-columns: 1fr;
  }
  
  .testimonials-grid {
    grid-template-columns: 1fr;
  }
  
  .btn-primary,
  .btn-secondary {
    padding: 0.8rem 1.5rem;
    font-size: 0.9rem;
  }
}

/* ========================================
   SERVICE DETAIL PAGE STYLES
   ======================================== */

.service-detail-page {
  padding-top: 80px;
}

/* Not Found */
.service-detail-not-found {
  min-height: 80vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  padding-top: 100px;
}

.service-detail-not-found h2 {
  font-size: 2.5rem;
}

.btn-back-home {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 1rem 2rem;
  background: #1a1a1a;
  color: #fff;
  text-decoration: none;
  font-family: 'Montserrat', sans-serif;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2px;
  font-size: 0.85rem;
  transition: all 0.3s ease;
}

.btn-back-home:hover {
  background: #333;
  transform: translateY(-2px);
}

/* SD Hero */
.sd-hero {
  position: relative;
  min-height: 85vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.sd-hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.sd-hero-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.sd-hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.7) 0%,
    rgba(0, 0, 0, 0.85) 100%
  );
}

.sd-hero-content {
  position: relative;
  z-index: 5;
  text-align: center;
  max-width: 900px;
  padding: 2rem 5%;
  animation: fadeUp 0.8s ease-out;
}

.sd-back-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: rgba(255, 255, 255, 0.7);
  text-decoration: none;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 2rem;
  transition: all 0.3s ease;
}

.sd-back-link:hover {
  color: #fff;
}

.sd-hero-icon {
  width: 80px;
  height: 80px;
  background: rgba(255, 255, 255, 0.1);
  border: 2px solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  color: #fff;
  margin: 0 auto 1.5rem;
}

.sd-hero-title {
  font-family: 'Playfair Display', serif;
  font-size: 3.5rem;
  font-weight: 600;
  color: #fff;
  margin-bottom: 1rem;
  line-height: 1.2;
}

.sd-hero-tagline {
  font-size: 1.2rem;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 3rem;
  line-height: 1.6;
}

.sd-hero-stats {
  display: flex;
  justify-content: center;
  gap: 3rem;
  flex-wrap: wrap;
}

.sd-stat {
  text-align: center;
}

.sd-stat-number {
  display: block;
  font-family: 'Playfair Display', serif;
  font-size: 2.5rem;
  font-weight: 600;
  color: #fff;
}

.sd-stat-label {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: rgba(255, 255, 255, 0.5);
}

/* SD Container */
.sd-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 5%;
}

/* SD Section Header */
.sd-section-header {
  text-align: center;
  margin-bottom: 3rem;
}

.sd-badge {
  display: inline-block;
  padding: 0.4rem 1.2rem;
  background: #f5f5f5;
  border: 1px solid var(--border-color);
  font-family: 'Montserrat', sans-serif;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 3px;
  color: var(--text-secondary);
  margin-bottom: 1rem;
}

.sd-section-header h2 {
  font-family: 'Playfair Display', serif;
  font-size: 2.5rem;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
}

.sd-section-header p {
  color: var(--text-secondary);
  font-size: 1.05rem;
}

/* SD Overview */
.sd-overview {
  padding: 5rem 0;
}

.sd-overview-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: start;
}

.sd-overview-text {
  font-size: 1.1rem;
  line-height: 1.9;
  color: var(--text-secondary);
}

.sd-benefits h3 {
  font-size: 1.5rem;
  margin-bottom: 1.5rem;
  color: var(--text-primary);
}

.sd-benefits-list {
  list-style: none;
  padding: 0;
}

.sd-benefits-list li {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 0.8rem 0;
  border-bottom: 1px solid var(--border-color);
  font-size: 0.95rem;
  color: var(--text-secondary);
}

.sd-benefits-list li:last-child {
  border-bottom: none;
}

.sd-check-icon {
  color: #1a1a1a;
  font-size: 1rem;
  margin-top: 3px;
  flex-shrink: 0;
}

/* SD Sub-Services */
.sd-sub-services {
  padding: 5rem 0;
  background: #fafafa;
}

.sd-sub-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}

.sd-sub-card {
  background: #fff;
  padding: 2.5rem;
  border: 1px solid var(--border-color);
  transition: all 0.3s ease;
}

.sd-sub-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-heavy);
  border-color: #1a1a1a;
}

.sd-sub-icon {
  width: 60px;
  height: 60px;
  background: #1a1a1a;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  margin-bottom: 1.5rem;
}

.sd-sub-card h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.3rem;
  font-weight: 600;
  margin-bottom: 1rem;
  color: var(--text-primary);
}

.sd-sub-card p {
  font-size: 0.95rem;
  line-height: 1.7;
  color: var(--text-secondary);
}

/* SD Process */
.sd-process {
  padding: 5rem 0;
}

.sd-process-timeline {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}

.sd-process-step {
  position: relative;
  padding: 2rem;
  border: 1px solid var(--border-color);
  background: #fff;
  transition: all 0.3s ease;
}

.sd-process-step:hover {
  border-color: #1a1a1a;
  box-shadow: var(--shadow-medium);
}

.sd-step-number {
  width: 50px;
  height: 50px;
  background: #1a1a1a;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 1.3rem;
  font-weight: 600;
  margin-bottom: 1.2rem;
}

.sd-step-content h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.2rem;
  font-weight: 600;
  margin-bottom: 0.8rem;
  color: var(--text-primary);
}

.sd-step-content p {
  font-size: 0.9rem;
  line-height: 1.7;
  color: var(--text-secondary);
}

/* SD Technologies */
.sd-technologies {
  padding: 5rem 0;
  background: #fafafa;
}

.sd-tech-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1rem;
}

.sd-tech-tag {
  padding: 0.8rem 1.5rem;
  background: #fff;
  border: 1px solid var(--border-color);
  font-family: 'Montserrat', sans-serif;
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text-primary);
  transition: all 0.3s ease;
  letter-spacing: 1px;
}

.sd-tech-tag:hover {
  background: #1a1a1a;
  color: #fff;
  border-color: #1a1a1a;
  transform: translateY(-2px);
}

/* SD FAQ */
.sd-faq {
  padding: 5rem 0;
}

.sd-faq-list {
  max-width: 800px;
  margin: 0 auto;
}

.sd-faq-item {
  border: 1px solid var(--border-color);
  margin-bottom: 1rem;
  transition: all 0.3s ease;
}

.sd-faq-item.active {
  border-color: #1a1a1a;
}

.sd-faq-question {
  width: 100%;
  padding: 1.5rem 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border: none;
  cursor: pointer;
  font-family: 'Poppins', sans-serif;
  font-size: 1rem;
  font-weight: 500;
  color: var(--text-primary);
  text-align: left;
  transition: all 0.3s ease;
}

.sd-faq-question:hover {
  background: #fafafa;
}

.sd-faq-question svg {
  flex-shrink: 0;
  margin-left: 1rem;
  color: var(--text-secondary);
}

.sd-faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease, padding 0.4s ease;
}

.sd-faq-answer.open {
  max-height: 300px;
  padding: 0 2rem 1.5rem;
}

.sd-faq-answer p {
  font-size: 0.95rem;
  line-height: 1.8;
  color: var(--text-secondary);
}

/* SD CTA */
.sd-cta {
  padding: 5rem 0;
  background: #1a1a1a;
}

.sd-cta-content {
  text-align: center;
  max-width: 700px;
  margin: 0 auto;
}

.sd-cta-quote {
  font-size: 2rem;
  color: rgba(255, 255, 255, 0.2);
  margin-bottom: 1.5rem;
}

.sd-cta-content h2 {
  font-family: 'Playfair Display', serif;
  font-size: 2.5rem;
  color: #fff;
  margin-bottom: 1rem;
}

.sd-cta-content p {
  font-size: 1.05rem;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 2rem;
}

.sd-cta-buttons {
  display: flex;
  justify-content: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.sd-btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 1rem 2.5rem;
  background: #fff;
  color: #1a1a1a;
  text-decoration: none;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2px;
  transition: all 0.3s ease;
}

.sd-btn-primary:hover {
  background: #f0f0f0;
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(255, 255, 255, 0.2);
}

.sd-btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 1rem 2.5rem;
  background: transparent;
  color: #fff;
  text-decoration: none;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2px;
  border: 1px solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.sd-btn-secondary:hover {
  background: #fff;
  color: #1a1a1a;
  border-color: #fff;
}

/* SD Navigation */
.sd-navigation {
  display: flex;
  border-top: 1px solid var(--border-color);
}

.sd-nav-link {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 2rem 3rem;
  text-decoration: none;
  transition: all 0.3s ease;
  background: #fff;
}

.sd-nav-link:hover {
  background: #fafafa;
}

.sd-nav-link.prev {
  border-right: 1px solid var(--border-color);
}

.sd-nav-link.next {
  justify-content: flex-end;
  text-align: right;
}

.sd-nav-link svg {
  font-size: 1.2rem;
  color: var(--text-secondary);
}

.sd-nav-label {
  display: block;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--text-secondary);
  margin-bottom: 0.3rem;
}

.sd-nav-title {
  display: block;
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--text-primary);
}

/* SD Responsive */
@media (max-width: 1024px) {
  .sd-sub-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .sd-process-timeline {
    grid-template-columns: repeat(2, 1fr);
  }

  .sd-hero-title {
    font-size: 2.8rem;
  }
}

@media (max-width: 768px) {
  .sd-hero {
    min-height: 70vh;
  }

  .sd-hero-title {
    font-size: 2.2rem;
  }

  .sd-hero-tagline {
    font-size: 1rem;
  }

  .sd-hero-stats {
    gap: 1.5rem;
  }

  .sd-stat-number {
    font-size: 2rem;
  }

  .sd-overview-content {
    grid-template-columns: 1fr;
  }

  .sd-sub-grid {
    grid-template-columns: 1fr;
  }

  .sd-process-timeline {
    grid-template-columns: 1fr;
  }

  .sd-section-header h2 {
    font-size: 2rem;
  }

  .sd-navigation {
    flex-direction: column;
  }

  .sd-nav-link.prev {
    border-right: none;
    border-bottom: 1px solid var(--border-color);
  }

  .sd-nav-link.next {
    justify-content: flex-start;
    text-align: left;
  }

  .sd-cta-content h2 {
    font-size: 2rem;
  }

  .sd-faq-question {
    padding: 1.2rem 1.5rem;
    font-size: 0.9rem;
  }

  .sd-faq-answer.open {
    padding: 0 1.5rem 1.2rem;
  }
}

@media (max-width: 480px) {
  .sd-hero-title {
    font-size: 1.8rem;
  }

  .sd-hero-stats {
    flex-direction: column;
    gap: 1rem;
  }

  .sd-sub-card {
    padding: 1.8rem;
  }

  .sd-cta-buttons {
    flex-direction: column;
    align-items: center;
  }
}

/* ===== NAV TOP BAR ===== */
.nav-top-bar {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  color: #fff;
  padding: 0.5rem 0;
  font-size: 0.8rem;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

.nav-top-content {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-top-text {
  color: #ffd700;
  font-weight: 600;
}

.nav-top-phone {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: #fff;
}

.nav-top-phone svg {
  color: #00d4ff;
}

.nav-top-right {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

/* ===== NAV DROPDOWN ===== */
.nav-dropdown-container {
  position: relative;
}

.nav-dropdown-container > a {
  display: flex;
  align-items: center;
  gap: 0.3rem;
}

.dropdown-arrow {
  font-size: 0.6rem;
  transition: transform 0.3s;
}

.nav-dropdown-container:hover .dropdown-arrow {
  transform: rotate(180deg);
}

.nav-dropdown {
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%) translateY(10px);
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.15);
  padding: 1.5rem;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 1000;
  min-width: 600px;
}

.nav-dropdown-container:hover .nav-dropdown {
  opacity: 1;
  visibility: visible;
  transform: translateX(-50%) translateY(0);
}

.nav-dropdown-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.5rem;
}

.nav-dropdown-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem 1rem;
  border-radius: 8px;
  color: #333 !important;
  text-decoration: none;
  transition: background 0.3s;
  font-size: 0.9rem;
}

.nav-dropdown-item:hover {
  background: #f0f7ff;
  color: #0066cc !important;
}

.nav-dropdown-item svg {
  color: #0066cc;
  font-size: 1.1rem;
  flex-shrink: 0;
}

.nav-dropdown-footer {
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px solid #eee;
  text-align: center;
}

.nav-dropdown-footer a {
  color: #0066cc !important;
  font-weight: 600;
  font-size: 0.9rem;
}

/* ===== HERO HIGHLIGHTS ===== */
.hero-highlights {
  display: flex;
  gap: 1.5rem;
  margin-top: 1.5rem;
  flex-wrap: wrap;
}

.hero-highlight-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: rgba(255,255,255,0.9);
  font-size: 0.9rem;
  font-weight: 500;
}

.hero-highlight-item svg {
  color: #ffd700;
  font-size: 1rem;
}

/* ===== HERO PARTNERS ===== */
.hero-partners {
  margin-top: 2.5rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(255,255,255,0.15);
}

.hero-partners .partner-label {
  color: rgba(255,255,255,0.6);
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 1rem;
}

.hero-partners .partner-logos {
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
  align-items: center;
}

.partner-logo-text {
  color: rgba(255,255,255,0.5);
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  transition: color 0.3s;
}

.partner-logo-text:hover {
  color: rgba(255,255,255,0.8);
}

/* ===== COURSE CARDS NEW STYLES ===== */
.course-tag {
  position: absolute;
  top: 1rem;
  left: 1rem;
  padding: 0.25rem 0.75rem;
  border-radius: 4px;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: #fff;
  z-index: 2;
}

.course-tag[data-tag="Bestseller"] { background: #ff6b35; }
.course-tag[data-tag="Trending"] { background: #e91e63; }
.course-tag[data-tag="Hot"] { background: #f44336; }
.course-tag[data-tag="Popular"] { background: #9c27b0; }
.course-tag[data-tag="New"] { background: #00bcd4; }
.course-tag[data-tag="In-Demand"] { background: #4caf50; }
.course-tag[data-tag="Top Rated"] { background: #ff9800; }
.course-tag[data-tag="Career Boost"] { background: #3f51b5; }

.course-rating {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin: 0.5rem 0;
  font-size: 0.85rem;
}

.rating-stars {
  display: flex;
  gap: 2px;
}

.rating-stars svg {
  color: #ddd;
  font-size: 0.8rem;
}

.rating-stars svg.star-filled {
  color: #ffc107;
}

.rating-number {
  font-weight: 700;
  color: #333;
}

.rating-count {
  color: #888;
  font-size: 0.8rem;
}

.course-meta {
  display: flex;
  gap: 1rem;
  margin: 0.5rem 0;
  font-size: 0.8rem;
  color: #666;
  flex-wrap: wrap;
}

.course-meta span {
  display: flex;
  align-items: center;
  gap: 0.3rem;
}

.course-price-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-top: 0.75rem;
}

.course-price-row .course-price-tag {
  font-size: 1.3rem;
  font-weight: 800;
  color: #0066cc;
}

.course-original-price {
  font-size: 0.95rem;
  color: #999;
  text-decoration: line-through;
}

/* ===== STATS SECTION UPDATES ===== */
.stats-header {
  text-align: center;
  margin-bottom: 3rem;
}

.stats-section {
  padding: 5rem 2rem;
  background: linear-gradient(135deg, #0a0a23 0%, #1a1a3e 50%, #0d0d2b 100%);
}

.stats-container {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 2rem;
  max-width: 1200px;
  margin: 0 auto;
}

.stat-item {
  text-align: center;
  padding: 1.5rem 1rem;
}

.stat-icon {
  font-size: 2rem;
  color: #00d4ff;
  margin-bottom: 0.75rem;
}

.stat-number {
  display: block;
  font-size: 2rem;
  font-weight: 800;
  color: #fff;
  margin-bottom: 0.5rem;
}

.stat-label {
  color: rgba(255,255,255,0.7);
  font-size: 0.85rem;
}

@media (max-width: 968px) {
  .stats-container {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 600px) {
  .stats-container {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* ===== TESTIMONIALS NEW STYLES ===== */
.testimonials {
  padding: 5rem 2rem;
  background: #f8f9fc;
}

.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  max-width: 1200px;
  margin: 0 auto;
}

.testimonial-card {
  background: #fff;
  border-radius: 16px;
  padding: 2rem;
  position: relative;
  box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  transition: transform 0.3s, box-shadow 0.3s;
  overflow: hidden;
}

.testimonial-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 12px 40px rgba(0,0,0,0.12);
}

.testimonial-hike-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  background: linear-gradient(135deg, #00c851, #00a040);
  color: #fff;
  padding: 0.3rem 0.8rem;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

.testimonial-hike-badge svg {
  font-size: 0.65rem;
}

.testimonial-course-tag {
  color: #0066cc;
  font-size: 0.8rem;
  font-weight: 600;
  margin-bottom: 1rem;
}

.testimonial-content {
  position: relative;
  margin-bottom: 1.5rem;
}

.testimonial-content .quote-icon {
  color: #e0e0e0;
  font-size: 1.5rem;
  margin-bottom: 0.5rem;
}

.testimonial-content p {
  color: #555;
  line-height: 1.7;
  font-size: 0.9rem;
}

.testimonial-career-path {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem;
  background: #f0f7ff;
  border-radius: 8px;
  margin-bottom: 1rem;
  font-size: 0.8rem;
}

.testimonial-career-path .prev-role {
  color: #888;
  text-decoration: line-through;
}

.testimonial-career-path .career-arrow {
  color: #00c851;
  font-size: 0.7rem;
  transform: rotate(45deg);
}

.testimonial-career-path .new-role {
  color: #0066cc;
  font-weight: 600;
}

.testimonial-author {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.5rem;
}

.author-image {
  width: 45px;
  height: 45px;
  border-radius: 50%;
  object-fit: cover;
}

.author-info h4 {
  font-size: 0.9rem;
  color: #333;
  margin-bottom: 0.1rem;
}

.author-info p {
  font-size: 0.75rem;
  color: #888;
}

.testimonial-rating {
  display: flex;
  gap: 2px;
}

.testimonial-rating svg {
  color: #ffc107;
  font-size: 0.8rem;
}

@media (max-width: 968px) {
  .testimonials-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 600px) {
  .testimonials-grid {
    grid-template-columns: 1fr;
  }
}

/* ===== FEATURES NEW STYLES ===== */
.features {
  padding: 5rem 2rem;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
  max-width: 1200px;
  margin: 0 auto;
}

.feature-card {
  background: #fff;
  border-radius: 12px;
  padding: 2rem 1.5rem;
  text-align: center;
  box-shadow: 0 2px 15px rgba(0,0,0,0.05);
  transition: all 0.3s;
  border: 1px solid #f0f0f0;
}

.feature-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  border-color: #0066cc;
}

.feature-card.feature-highlight {
  background: linear-gradient(135deg, #0066cc, #0052a3);
  color: #fff;
  border-color: transparent;
}

.feature-card.feature-highlight .feature-icon {
  background: rgba(255,255,255,0.2);
  color: #fff;
}

.feature-card.feature-highlight h3 {
  color: #fff;
}

.feature-card.feature-highlight p {
  color: rgba(255,255,255,0.85);
}

.feature-icon {
  width: 60px;
  height: 60px;
  border-radius: 12px;
  background: #f0f7ff;
  color: #0066cc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  margin: 0 auto 1rem;
}

.feature-card h3 {
  font-size: 1rem;
  margin-bottom: 0.5rem;
  color: #333;
}

.feature-card p {
  font-size: 0.85rem;
  color: #666;
  line-height: 1.6;
}

@media (max-width: 968px) {
  .features-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 600px) {
  .features-grid {
    grid-template-columns: 1fr;
  }
}

/* ===== FOOTER NEW STYLES ===== */
.footer-newsletter {
  background: linear-gradient(135deg, #0066cc, #0052a3);
  padding: 3rem 2rem;
}

.newsletter-content {
  max-width: 600px;
  margin: 0 auto;
  text-align: center;
}

.newsletter-content h3 {
  color: #fff;
  font-size: 1.5rem;
  margin-bottom: 0.5rem;
}

.newsletter-content p {
  color: rgba(255,255,255,0.8);
  margin-bottom: 1.5rem;
}

.newsletter-form {
  display: flex;
  gap: 0;
  max-width: 480px;
  margin: 0 auto;
}

.newsletter-form input {
  flex: 1;
  padding: 0.85rem 1.25rem;
  border: none;
  border-radius: 8px 0 0 8px;
  font-size: 0.9rem;
  outline: none;
}

.newsletter-form button {
  padding: 0.85rem 1.5rem;
  border: none;
  border-radius: 0 8px 8px 0;
  background: #ffd700;
  color: #1a1a2e;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  transition: background 0.3s;
  white-space: nowrap;
}

.newsletter-form button:hover {
  background: #ffed4a;
}

.footer {
  background: #0a0a23;
  color: #fff;
}

.footer-content {
  display: grid;
  grid-template-columns: 1.5fr repeat(4, 1fr);
  gap: 2rem;
  max-width: 1200px;
  margin: 0 auto;
  padding: 4rem 2rem 2rem;
}

.footer-brand p {
  color: rgba(255,255,255,0.7);
  font-size: 0.85rem;
  line-height: 1.7;
  margin-bottom: 1.25rem;
}

.footer-contact-info {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin-bottom: 1.25rem;
  font-size: 0.8rem;
  color: rgba(255,255,255,0.6);
}

.footer-contact-info div {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.footer-contact-info svg {
  color: #00d4ff;
  flex-shrink: 0;
}

.footer-logo {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.footer-logo-icon {
  font-size: 1.5rem;
  color: #00d4ff;
}

.footer-logo-text {
  font-size: 1.3rem;
  font-weight: 800;
  color: #fff;
}

.footer-social {
  display: flex;
  gap: 0.75rem;
}

.social-link {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  transition: all 0.3s;
  font-size: 0.9rem;
}

.social-link:hover {
  background: #0066cc;
  transform: translateY(-3px);
}

.footer-links h4 {
  color: #fff;
  font-size: 1rem;
  margin-bottom: 1.25rem;
  font-weight: 700;
}

.footer-links ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.footer-links ul li {
  margin-bottom: 0.6rem;
}

.footer-links ul li a {
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  font-size: 0.85rem;
  transition: color 0.3s;
}

.footer-links ul li a:hover {
  color: #00d4ff;
}

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding: 1.5rem 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  max-width: 1200px;
  margin: 0 auto;
  flex-wrap: wrap;
  gap: 1rem;
}

.footer-bottom p {
  color: rgba(255,255,255,0.5);
  font-size: 0.8rem;
}

.footer-bottom-links {
  display: flex;
  gap: 1.5rem;
}

.footer-bottom-links a {
  color: rgba(255,255,255,0.5);
  text-decoration: none;
  font-size: 0.8rem;
  transition: color 0.3s;
}

.footer-bottom-links a:hover {
  color: #00d4ff;
}

@media (max-width: 968px) {
  .footer-content {
    grid-template-columns: repeat(2, 1fr);
  }

  .footer-brand {
    grid-column: 1 / -1;
  }

  .newsletter-form {
    flex-direction: column;
  }
  
  .newsletter-form input {
    border-radius: 8px;
  }
  
  .newsletter-form button {
    border-radius: 8px;
    justify-content: center;
  }
}

@media (max-width: 600px) {
  .footer-content {
    grid-template-columns: 1fr;
  }

  .footer-bottom {
    flex-direction: column;
    text-align: center;
  }

  .nav-top-bar { display: none; }
  
  .nav-dropdown {
    min-width: 300px;
  }
  
  .nav-dropdown-grid {
    grid-template-columns: 1fr;
  }
}

/* ===== ABOUT NEW STYLES ===== */
.about-badges {
  display: flex;
  gap: 1.5rem;
  margin-top: 1.5rem;
  flex-wrap: wrap;
}

.about-badge-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 1rem;
  background: #f0f7ff;
  border-radius: 8px;
  font-size: 0.85rem;
  font-weight: 600;
  color: #0066cc;
}

.badge-icon {
  font-size: 1.2rem;
}

.about-partners {
  text-align: center;
  padding: 3rem 0 0;
  margin-top: 3rem;
  border-top: 1px solid #eee;
}

.about-partners .partner-label {
  color: #888;
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 1.25rem;
}

.about-partners .partner-logos {
  display: flex;
  justify-content: center;
  gap: 2.5rem;
  flex-wrap: wrap;
}

.about-partners .partner-logo-text {
  color: #bbb;
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  transition: color 0.3s;
}

.about-partners .partner-logo-text:hover {
  color: #0066cc;
}

/* ===== NAV RIGHT ===== */
.nav-right {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.nav-search-btn {
  background: none;
  border: none;
  color: #333;
  font-size: 1.1rem;
  cursor: pointer;
  padding: 0.5rem;
  transition: color 0.3s;
}

.nav-search-btn:hover {
  color: #0066cc;
}
