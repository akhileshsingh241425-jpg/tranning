# ==================== SMTP Email Configuration ====================
# Configure these to enable email notifications on new enquiries
# Emails are sent to NOTIFICATION_EMAIL when someone submits a contact/enquiry form

# SMTP Server (Gmail: smtp.gmail.com, Outlook: smtp-mail.outlook.com)
SMTP_SERVER=smtp.gmail.com

# SMTP Port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP Username (the email account that sends the emails)
SMTP_USERNAME=

# SMTP Password (for Gmail, use an App Password: https://myaccount.google.com/apppasswords)
SMTP_PASSWORD=

# Use TLS (true/false) - recommended for port 587
SMTP_USE_TLS=true

# Email address to receive enquiry notifications
NOTIFICATION_EMAIL=contact@trainingprotec.com

# Sender email (defaults to SMTP_USERNAME if not set)
SENDER_EMAIL=

# Number of days after enquiry to send reminder email (default: 10)
REMINDER_DAYS=10

# Secret key for cron endpoint /api/cron/reminders (leave empty to disable auth)
CRON_SECRET=
